# ================================================================
# BotSquad — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ================================================================

# ── DATABASE ─────────────────────────────────────────────────────
# Used by: backend/src/db/index.js + docker-compose.yml
POSTGRES_USER=botsquad
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=botsquad
DB_HOST=localhost         # Use "db" inside Docker Compose
DB_PORT=5432
DB_USER=botsquad
DB_PASSWORD=changeme_strong_password
DB_NAME=botsquad

# ── SECURITY ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_at_least_32_chars
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_SEND_MODE=document
SESSION_SECRET=your_session_secret_at_least_32_chars
ENCRYPTION_KEY=your_32_char_encryption_key_here!

# ── SERVER ───────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
BACKEND_PUBLIC_URL=http://YOUR_VPS_IP:4000  # or https://api.yourdomain.com
FRONTEND_URL=http://YOUR_VPS_IP:3000        # or https://yourdomain.com

# ── CORS ─────────────────────────────────────────────────────────
# In production, list exact origins. Never use * with credentials.
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com
# For development:
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ── PRIVATE ACCESS (optional gate) ───────────────────────────────
# When true, the app requires a token before the login screen
APP_PRIVATE_MODE=false
APP_ACCESS_TOKEN=             # Generate with: openssl rand -hex 32
APP_COOKIE_SECURE=auto        # auto | true | false
#   auto  = secure when behind HTTPS proxy (recommended)
#   true  = always secure (requires HTTPS — breaks HTTP-only installs)
#   false = never secure (use only for local HTTP dev)

# ── REGISTRATION ─────────────────────────────────────────────────
# When true, only seed:admin can create users
DISABLE_PUBLIC_REGISTRATION=true
ALLOW_SIGNUP=false
AUTH_PRIVATE_MODE=true
ALLOW_FIRST_ADMIN_SETUP=false
# First admin — used by: npm run seed:admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme_strong_password
ADMIN_NAME=Admin

# ── AI PROVIDERS ─────────────────────────────────────────────────
# At least one is required. OpenAI is the primary/responsible provider.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Additional keys for auto-rotation (optional)
# OPENAI_API_KEY_2=sk-...
# OPENAI_API_KEY_3=sk-...
# OPENAI_API_KEYS=sk-key1,sk-key2,sk-key3   (alternative: comma-separated list)

OPENAI_KEY_ROTATION_ENABLED=true
OPENAI_KEY_ROTATION_STRATEGY=usage_aware
OPENAI_KEY_COOLDOWN_MINUTES=30

# Other AI providers (all optional — configure via app Settings)
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=

# ── STORAGE ──────────────────────────────────────────────────────
# Docker: these map to named volumes (see docker-compose.yml)
# VPS without Docker: create these directories and set write permissions
UPLOAD_DIR=/app/storage/uploads
OUTPUT_DIR=/app/storage/outputs
IR_DIR=/app/storage/irs
TEMP_DIR=/app/storage/temp
PREVIEW_DIR=/app/storage/previews
LOG_DIR=/app/storage/logs
VIDEO_DIR=/app/storage/videos
STORAGE_PATH=/app/storage

# ── VIDEO ────────────────────────────────────────────────────────
VIDEO_METADATA_ANALYSIS_ENABLED=true
VIDEO_METADATA_SANITIZE_ENABLED=true
VIDEO_WRITE_CUSTOM_METADATA=true
VIDEO_DEFAULT_AUTHOR=BotSquad
VIDEO_DEFAULT_ARTIST=BotSquad
VIDEO_DEFAULT_COMMENT=Created with BotSquad
VIDEO_DEFAULT_TITLE_PREFIX=BotSquad Clip
VIDEO_DEFAULT_TAGS=tiktok,kwai,shorts,reels
YTDLP_ENABLED=false                # Requires yt-dlp installed on VPS
VIDEO_YOUTUBE_IMPORT_ENABLED=false # Alias for YTDLP_ENABLED
VIDEO_YOUTUBE_DOWNLOADER=yt-dlp
YTDLP_FORMAT=bv*[height<=1080]+ba/b[height<=1080]/bv*+ba/best
REMOTION_ENABLED=false
VIDEO_RENDER_ENGINE=ffmpeg
VIDEO_PREMIUM_RENDER_ENGINE=ffmpeg_remotion
VIDEO_OPENAI_DISABLED=true
# Engine profile: legacy | pro | full_studio
# legacy = SmartCut only, pro = Motor Pro with fallbacks, full_studio = blocked when tool missing
VIDEO_ENGINE_PROFILE=pro

# ── AUDIO / CAMILLA ──────────────────────────────────────────────
CAMILLA_BIN=/usr/local/bin/camilladsp  # Optional — ir-processor is fallback
CAMILLA_CONFIG_DIR=/app/camilla-configs

# ── SPORTS DATA PROVIDERS (all optional - free-first) ────────────
# TheSportsDB works without a key (limited free tier)
THESPORTSDB_API_KEY=
# football-data.org: free key at football-data.org (10 calls/min)
FOOTBALL_DATA_API_KEY=
# API-Football: 100 req/day free at api-sports.io
API_FOOTBALL_KEY=
# API_FOOTBALL_PROVIDER=apisports (direct) | rapidapi (via RapidAPI gateway)
API_FOOTBALL_PROVIDER=apisports
RAPIDAPI_KEY=
# Others (optional):
SPORTMONKS_API_KEY=
ISPORTS_API_KEY=
SOCCERDATA_API_KEY=
HIGHLIGHTLY_API_KEY=
LIVE_SCORE_API_KEY=
SPORTSDATAIO_API_KEY=
ALLSPORTS_API_KEY=
API4SPORTS_KEY=
THESPORTS_API_KEY=
ODDS_API_KEY=
ODDS_API_IO_KEY=
# Enterprise (optional):
# SPORTRADAR_API_KEY=
# STATS_PERFORM_API_KEY=
# OPTA_API_KEY=

SPORTS_DATA_PROVIDER_PRIORITY=thesportsdb,football_data,api_football,highlightly,manual
SPORTS_CACHE_ENABLED=true
SPORTS_CACHE_TTL_HOURS=12
SPORTS_FIXTURE_CACHE_TTL_HOURS=6
SPORTS_TEAM_CACHE_TTL_HOURS=24
SPORTS_STANDINGS_CACHE_TTL_HOURS=12
SPORTS_ODDS_CACHE_TTL_MINUTES=30

# ── SOCIAL RESEARCH APIs (optional) ──────────────────────────────
YOUTUBE_API_KEY=
RAPIDAPI_KEY=        # shared with API-Football if using RapidAPI
APIFY_TOKEN=

# ── GOOGLE DRIVE (optional) ──────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/drive/callback

# ── FRONTEND BUILD ───────────────────────────────────────────────
# Set in frontend/.env before building
# /api = use nginx proxy (recommended for Docker/production)
# http://IP:4000 = direct backend URL (for non-Docker setups)
VITE_API_URL=/api
